# =============================================================================
# Zone New Checker v3.1 - Docker Ignore Configuration
# Prevents unnecessary files from being included in Docker build context
# =============================================================================

# ------------------------------------------------------------------------------
# Dependencies & Build Output
# ------------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Next.js build output
.next/
out/
dist/

# ------------------------------------------------------------------------------
# Version Control
# ------------------------------------------------------------------------------
.git/
.gitignore
.gitattributes
.github/

# ------------------------------------------------------------------------------
# Environment Files (Security)
# ------------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# ------------------------------------------------------------------------------
# IDE & Editor Config
# ------------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ------------------------------------------------------------------------------
# Documentation & Project Files
# ------------------------------------------------------------------------------
*.md
!README.md
LICENSE
CHANGELOG.md
CODE_OF_CONDUCT.md
CONTRIBUTING.md
SECURITY.md
VERCEL_CHECKLIST.md

# ------------------------------------------------------------------------------
# Testing & Coverage
# ------------------------------------------------------------------------------
coverage/
.nyc_output/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__/
__mocks__/

# ------------------------------------------------------------------------------
# Local Development
# ------------------------------------------------------------------------------
references/
*.local
temp/
tmp/
.cache/

# ------------------------------------------------------------------------------
# Docker (prevent recursion)
# ------------------------------------------------------------------------------
Dockerfile
docker-compose.yml
docker-compose.override.yml
.dockerignore

# ------------------------------------------------------------------------------
# CI/CD
# ------------------------------------------------------------------------------
.github/
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml

# ------------------------------------------------------------------------------
# Misc
# ------------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.backup
