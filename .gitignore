# =============================================================================
# Zone New Checker v3.0 - Comprehensive Git Ignore
# =============================================================================

# ------------------------------------------------------------------------------
# Dependencies & Build Output
# ------------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Next.js build output
.next/
out/
dist/

# Production builds
build/
*.tsbuildinfo
next-env.d.ts

# ------------------------------------------------------------------------------
# Environment Files (Security Critical)
# ------------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
!.env.example

# Secret files (backup protection)
*.secret
*.key
*.pem
*.crt
*.cer
*.p12
*.pfx

# ------------------------------------------------------------------------------
# IDE & Editor
# ------------------------------------------------------------------------------
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim/Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
*~
.#*

# ------------------------------------------------------------------------------
# OS Generated Files
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ------------------------------------------------------------------------------
# Logs & Debug
# ------------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage & Testing
coverage/
*.lcov
.nyc_output/
.vitest/
playwright-report/
test-results/

# ------------------------------------------------------------------------------
# Package Managers
# ------------------------------------------------------------------------------
# npm
.npm
*.tgz

# Yarn
.yarn/
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions
.yarnrc.yml

# pnpm
pnpm-lock.yaml
.pnpm-store/

# ------------------------------------------------------------------------------
# Deployment Platforms
# ------------------------------------------------------------------------------
.vercel/
.netlify/
.serverless/
.amplify/
firebase-debug.log
.firebaserc

# ------------------------------------------------------------------------------
# Docker
# ------------------------------------------------------------------------------
docker-compose.override.yml
*.dockerfile~backup

# ------------------------------------------------------------------------------
# Misc
# ------------------------------------------------------------------------------
# Temporary files
*.tmp
*.temp
*.bak
*.backup
*.orig

# Local reference files
references/
docs/_private/
scripts/_local/

# Large media files
*.mp4
*.mov
*.avi
*.wmv
*.mkv
*.webm

