# =============================================================================
# Zone New Checker v3.0 - Environment Configuration Example
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control
# =============================================================================

# ------------------------------------------------------------------------------
# Cloudflare Turnstile Configuration (Required for production)
# Get your keys at: https://dash.cloudflare.com/turnstile
# ------------------------------------------------------------------------------

# Public site key - visible in browser, used by client-side widget
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Secret key - server-side only, never exposed to browser
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Optional: Comma-separated list of allowed hostnames for verification
# Leave empty to allow all hostnames
TURNSTILE_ALLOWED_HOSTNAMES=localhost,example.com

# ------------------------------------------------------------------------------
# Security Configuration (Required)
# ------------------------------------------------------------------------------

# Random secret for signing verification cookies (min 32 characters)
# Generate with: openssl rand -base64 32
HUMAN_COOKIE_SECRET=your_random_secret_here_min_32_chars

# ------------------------------------------------------------------------------
# Vercel Analytics (Optional)
# Enable only when deploying to Vercel
# ------------------------------------------------------------------------------

# Enable Vercel Web Analytics
NEXT_PUBLIC_ENABLE_VERCEL_ANALYTICS=1

# Enable Vercel Speed Insights
NEXT_PUBLIC_ENABLE_VERCEL_SPEED_INSIGHTS=1

# ------------------------------------------------------------------------------
# Development Settings (Optional)
# ------------------------------------------------------------------------------

# Set to 1 to disable verification in development (NOT for production)
# SKIP_HUMAN_VERIFICATION=1

# Node environment (automatically set by Next.js)
# NODE_ENV=development
